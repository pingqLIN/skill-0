{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-0.local/schema/production-external-control-keyring.schema.json",
  "title": "Skill-0 production external-control verifier keyring",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "keys", "revoked_evidence_ids"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key_id",
          "operator_id",
          "roles",
          "environments",
          "public_key_base64",
          "revoked"
        ],
        "properties": {
          "key_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "operator_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "roles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1, "maxLength": 128}
          },
          "environments": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1, "maxLength": 128}
          },
          "public_key_base64": {"type": "string", "minLength": 1, "maxLength": 128},
          "revoked": {"type": "boolean"}
        }
      }
    },
    "revoked_evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
      }
    }
  }
}
