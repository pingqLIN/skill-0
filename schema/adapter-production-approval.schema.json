{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-0.local/schema/adapter-production-approval.schema.json",
  "title": "SKILL-0 Adapter Production Approval",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "approval_id", "decision", "adapter", "manifest_digest", "certification_evidence_digest", "environment", "allowed_operations", "approved_by", "approved_at", "expires_at", "signature"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "approval_id": { "type": "string", "format": "uuid" },
    "decision": { "enum": ["approved", "revoked"] },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "kind", "target", "artifact_digest"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "artifact_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "manifest_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "certification_evidence_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "environment": { "type": "string", "minLength": 1 },
    "allowed_operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonical_skill_id", "action_id", "resource_kind", "operation"],
        "properties": {
          "canonical_skill_id": { "type": "string", "minLength": 1 },
          "action_id": { "type": "string", "minLength": 1 },
          "resource_kind": { "type": "string", "minLength": 1 },
          "operation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "approved_by": { "type": "string", "minLength": 1 },
    "approved_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "revoked_by": { "type": "string", "minLength": 1 },
    "revoked_at": { "type": "string", "format": "date-time" },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "hmac-sha256" },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "decision": { "const": "revoked" } } },
      "then": { "required": ["revoked_by", "revoked_at"] }
    },
    {
      "if": { "properties": { "decision": { "const": "approved" } } },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["revoked_by"] },
            { "required": ["revoked_at"] }
          ]
        }
      }
    }
  ]
}
