{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-0.local/schema/evidence-summary.schema.json",
  "title": "SKILL-0 Evidence Summary Projection",
  "description": "Derived quality/provenance projection. Not an ARD category and not the source of execution truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projection_version",
    "skill_ref",
    "generated_at",
    "source_event_watermark",
    "counts",
    "sample_size",
    "confidence"
  ],
  "properties": {
    "projection_version": {
      "const": "1.0.0"
    },
    "skill_ref": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_event_watermark": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of immutable runtime events included in this projection."
    },
    "counts": {
      "type": "object",
      "required": [
        "succeeded",
        "failed",
        "compensated",
        "recovery_failed"
      ],
      "properties": {
        "succeeded": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "compensated": {
          "type": "integer",
          "minimum": 0
        },
        "recovery_failed": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "sample_size": {
      "type": "integer",
      "minimum": 0
    },
    "success_rate": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "known_failure_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "element_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:a_[0-9]{3}(?:_[a-z0-9]+)*|r_[0-9]{3}|d_[0-9]{3})$"
      },
      "uniqueItems": true
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
