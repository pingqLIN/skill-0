{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-0.local/schema/runtime-run-evidence.schema.json",
  "title": "SKILL-0 Per-Run Evidence Projection",
  "description": "Required per-run envelope layered on the aggregate Evidence summary contract.",
  "type": "object",
  "required": [
    "projection_version",
    "skill_ref",
    "run_ref",
    "event_count",
    "last_event_type",
    "generated_at",
    "source_event_watermark",
    "counts",
    "sample_size",
    "confidence"
  ],
  "properties": {
    "run_ref": {
      "type": "object",
      "required": [
        "run_id",
        "status"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "created",
            "planned",
            "preflight",
            "awaiting_approval",
            "ready",
            "running",
            "validating",
            "succeeded",
            "failed",
            "recovery_pending",
            "compensating",
            "compensated",
            "recovery_failed",
            "reconciliation_required",
            "hitl_required",
            "denied",
            "cancelled"
          ]
        }
      },
      "additionalProperties": false
    },
    "event_count": {
      "type": "integer",
      "minimum": 1
    },
    "last_event_type": {
      "type": "string",
      "minLength": 1
    },
    "source_event_watermark": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": true
}
