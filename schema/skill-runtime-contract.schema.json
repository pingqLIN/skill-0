{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-0.local/schema/skill-runtime-contract.schema.json",
  "title": "SKILL-0 ARD Runtime Contract",
  "description": "Additive runtime bindings for an existing Action/Rule/Directive decomposition. Evidence is a derived envelope, not a fourth ARD category.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill_ref",
    "action_bindings",
    "governance",
    "directive_manifest"
  ],
  "properties": {
    "schema_version": {
      "const": "4.0.0"
    },
    "skill_ref": {
      "$ref": "#/$defs/skillRef"
    },
    "action_bindings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/actionBinding"
      },
      "contains": {
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "const": "primary"
          }
        }
      },
      "minContains": 1
    },
    "governance": {
      "$ref": "#/$defs/governance"
    },
    "directive_manifest": {
      "$ref": "#/$defs/directiveManifest"
    },
    "evidence_policy": {
      "$ref": "#/$defs/evidencePolicy"
    },
    "feature_flags": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "properties": {
        "real_execution": {
          "type": "boolean",
          "default": false
        }
      },
      "default": {
        "real_execution": false
      }
    }
  },
  "$defs": {
    "actionId": {
      "type": "string",
      "pattern": "^a_[0-9]{3}(?:_[a-z0-9]+)*$"
    },
    "ruleId": {
      "type": "string",
      "pattern": "^r_[0-9]{3}$"
    },
    "directiveId": {
      "type": "string",
      "pattern": "^d_[0-9]{3}$"
    },
    "skillRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "target"
      ],
      "properties": {
        "kind": {
          "enum": [
            "python",
            "mcp",
            "openai_agents",
            "langgraph",
            "command",
            "test"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600000
        }
      }
    },
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "resource_kind",
        "operation"
      ],
      "properties": {
        "classification": {
          "enum": [
            "read_only",
            "bounded_write",
            "destructive_write"
          ]
        },
        "resource_kind": {
          "enum": [
            "none",
            "filesystem",
            "database",
            "external_api",
            "git",
            "process",
            "network",
            "other"
          ]
        },
        "resource_name": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "minLength": 1
        },
        "external_id_pointer": {
          "type": "string",
          "pattern": "^/"
        },
        "commit_marker_pointer": {
          "type": "string",
          "pattern": "^/"
        },
        "primary_idempotency_key_template": {
          "type": "string",
          "minLength": 1
        },
        "resource_lock_key_template": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level"
      ],
      "properties": {
        "level": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "approval_required": {
          "type": "boolean",
          "default": false
        },
        "data_sensitivity": {
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "precondition_rule_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ruleId"
          },
          "uniqueItems": true
        },
        "postcondition_rule_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ruleId"
          },
          "uniqueItems": true
        }
      }
    },
    "compensation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy"
      ],
      "properties": {
        "strategy": {
          "enum": [
            "none",
            "auto_rollback",
            "manual_approval",
            "human_intervention"
          ]
        },
        "action_id": {
          "$ref": "#/$defs/actionId"
        },
        "idempotent": {
          "type": "boolean"
        },
        "idempotency_key_template": {
          "type": "string",
          "minLength": 1
        },
        "parameters_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^(?:$|/)"
          }
        },
        "acceptable_errors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "default": 3
        },
        "approval_policy": {
          "type": "string",
          "minLength": 1
        },
        "review_payload_schema": {
          "type": "object"
        },
        "escalation_queue": {
          "type": "string",
          "minLength": 1
        },
        "operator_instructions": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "strategy"
            ],
            "properties": {
              "strategy": {
                "const": "none"
              }
            }
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "action_id"
                  ]
                },
                {
                  "required": [
                    "idempotency_key_template"
                  ]
                },
                {
                  "required": [
                    "parameters_mapping"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "required": [
              "strategy"
            ],
            "properties": {
              "strategy": {
                "const": "auto_rollback"
              }
            }
          },
          "then": {
            "required": [
              "action_id",
              "idempotent",
              "idempotency_key_template",
              "parameters_mapping"
            ],
            "properties": {
              "idempotent": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "strategy"
            ],
            "properties": {
              "strategy": {
                "const": "manual_approval"
              }
            }
          },
          "then": {
            "required": [
              "approval_policy",
              "review_payload_schema"
            ]
          }
        },
        {
          "if": {
            "required": [
              "strategy"
            ],
            "properties": {
              "strategy": {
                "const": "human_intervention"
              }
            }
          },
          "then": {
            "required": [
              "escalation_queue",
              "operator_instructions"
            ]
          }
        }
      ]
    },
    "actionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "role",
        "adapter",
        "effect",
        "risk",
        "compensation"
      ],
      "properties": {
        "action_id": {
          "$ref": "#/$defs/actionId"
        },
        "role": {
          "enum": [
            "primary",
            "compensation"
          ]
        },
        "adapter": {
          "$ref": "#/$defs/adapter"
        },
        "effect": {
          "$ref": "#/$defs/effect"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "validation": {
          "$ref": "#/$defs/validation"
        },
        "compensation": {
          "$ref": "#/$defs/compensation"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "effect": {
                "required": [
                  "classification"
                ],
                "properties": {
                  "classification": {
                    "const": "read_only"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "compensation": {
                "properties": {
                  "strategy": {
                    "const": "none"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "effect": {
                "required": [
                  "classification"
                ],
                "properties": {
                  "classification": {
                    "enum": [
                      "bounded_write",
                      "destructive_write"
                    ]
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "effect": {
                "required": [
                  "resource_name",
                  "primary_idempotency_key_template",
                  "resource_lock_key_template"
                ],
                "properties": {
                  "resource_kind": {
                    "not": {
                      "const": "none"
                    }
                  }
                }
              },
              "compensation": {
                "properties": {
                  "strategy": {
                    "enum": [
                      "auto_rollback",
                      "manual_approval",
                      "human_intervention"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "effect": {
                "required": [
                  "classification"
                ],
                "properties": {
                  "classification": {
                    "const": "destructive_write"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "risk": {
                "required": [
                  "approval_required"
                ],
                "properties": {
                  "approval_required": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      ]
    },
    "rulePolicyBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "decision",
        "evaluator"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/ruleId"
        },
        "decision": {
          "enum": [
            "allow",
            "deny",
            "require_approval",
            "classify"
          ]
        },
        "evaluator": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_.-]*$"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000,
          "default": 100
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_decision",
        "rule_policy_bindings"
      ],
      "properties": {
        "default_decision": {
          "enum": [
            "deny",
            "require_approval"
          ]
        },
        "rule_policy_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rulePolicyBinding"
          }
        }
      }
    },
    "directiveManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include",
        "token_budget"
      ],
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/directiveId"
          },
          "uniqueItems": true
        },
        "exclude": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/directiveId"
          },
          "uniqueItems": true
        },
        "token_budget": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "evidencePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projection_version": {
          "type": "string",
          "minLength": 1
        },
        "minimum_sample_size": {
          "type": "integer",
          "minimum": 0
        },
        "require_human_review_for_promotion": {
          "type": "boolean",
          "default": true
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
