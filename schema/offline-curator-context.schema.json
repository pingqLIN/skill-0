{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skill-parser.pingqlin.dev/schema/curation/v1/offline-curator-context.schema.json",
  "title": "Skill-0 Offline Curator Skill Context",
  "description": "A read-only snapshot of skill revisions supplied to the offline Curator.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "contract_version",
    "snapshot_id",
    "captured_at",
    "skills"
  ],
  "properties": {
    "contract_version": {
      "const": "1.0.0"
    },
    "snapshot_id": {
      "type": "string",
      "pattern": "^curctx_[A-Za-z0-9][A-Za-z0-9._-]{5,127}$"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/skill_snapshot"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "checksum": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "skill_id": {
      "type": "string",
      "pattern": "^(claude|mcp)__[a-z_]+__[a-z_]+$"
    },
    "ard_summary": {
      "type": "object",
      "properties": {
        "actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "directives": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      },
      "additionalProperties": false
    },
    "skill_snapshot": {
      "type": "object",
      "required": [
        "skill_id",
        "revision_id",
        "revision_checksum",
        "artifact_ref",
        "summary"
      ],
      "properties": {
        "skill_id": {
          "$ref": "#/definitions/skill_id"
        },
        "revision_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "revision_checksum": {
          "$ref": "#/definitions/checksum"
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "ard_summary": {
          "$ref": "#/definitions/ard_summary"
        }
      },
      "additionalProperties": false
    }
  }
}
