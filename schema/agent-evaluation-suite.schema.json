{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-0.local/schema/agent-evaluation-suite.schema.json",
  "title": "SKILL-0 Agent Evaluation Suite",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_type",
    "benchmark_id",
    "suite_digest",
    "freeze",
    "coverage",
    "thresholds",
    "cases"
  ],
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "document_type": {"const": "agent-evaluation-suite"},
    "benchmark_id": {
      "type": "string",
      "pattern": "^agent-eval:[a-z0-9][a-z0-9_-]*:v[0-9]+$"
    },
    "suite_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "freeze": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {"enum": ["draft", "reviewed-frozen"]},
        "reviewer": {"type": "string", "pattern": "^agent:[a-z0-9][a-z0-9_-]*$"},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "review_method": {"const": "independent-agent-review"},
        "review_scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "case-content",
              "thresholds",
              "taxonomy-coverage",
              "code-allowlists"
            ]
          }
        },
        "review_attestation": {"const": "unverified"}
      },
      "allOf": [
        {
          "if": {"properties": {"state": {"const": "reviewed-frozen"}}},
          "then": {
            "required": [
              "reviewer",
              "reviewed_at",
              "review_method",
              "review_scope",
              "review_attestation"
            ]
          }
        },
        {
          "if": {"properties": {"state": {"const": "draft"}}},
          "then": {
            "not": {
              "anyOf": [
                {"required": ["reviewer"]},
                {"required": ["reviewed_at"]},
                {"required": ["review_method"]},
                {"required": ["review_scope"]},
                {"required": ["review_attestation"]}
              ]
            }
          }
        }
      ]
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_categories"],
      "properties": {
        "required_categories": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["authority", "knowledge", "planning", "execution", "recovery", "evidence"]
          }
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_outcome_accuracy",
        "min_evidence_recall",
        "max_forbidden_claim_rate",
        "min_safety_outcome_accuracy"
      ],
      "properties": {
        "min_outcome_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "min_evidence_recall": {"type": "number", "minimum": 0, "maximum": 1},
        "max_forbidden_claim_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "min_safety_outcome_accuracy": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "outcome": {
      "enum": ["succeeded", "failed", "denied", "hitl-required", "reconciliation-required"]
    },
    "code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "category",
        "safety_critical",
        "input",
        "expected"
      ],
      "properties": {
        "case_id": {"type": "string", "pattern": "^ae_[0-9]{3}$"},
        "category": {
          "enum": ["authority", "knowledge", "planning", "execution", "recovery", "evidence"]
        },
        "safety_critical": {"type": "boolean"},
        "input": {"type": "object"},
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome",
            "required_evidence_codes",
            "allowed_evidence_codes",
            "forbidden_claim_codes",
            "allowed_claim_codes"
          ],
          "properties": {
            "outcome": {"$ref": "#/$defs/outcome"},
            "required_evidence_codes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/code"}
            },
            "allowed_evidence_codes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/code"}
            },
            "forbidden_claim_codes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/code"}
            },
            "allowed_claim_codes": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/code"}
            }
          }
        }
      }
    }
  }
}
