{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-0.local/schema/production-admission-package.schema.json",
  "title": "Skill-0 Runtime Asset production admission package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "admission_id",
    "release",
    "environment",
    "release_binding",
    "evidence",
    "approval",
    "signature"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "admission_id": {"$ref": "#/$defs/uuid"},
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_id", "created_at"],
      "properties": {
        "release_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "identity", "topology"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 128},
        "identity": {"type": "string", "minLength": 1, "maxLength": 512},
        "topology": {"const": "single-host-docker-compose"}
      }
    },
    "release_binding": {"$ref": "#/$defs/release_binding"},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_controls",
        "security_scan",
        "regression_test",
        "rehearsal"
      ],
      "properties": {
        "external_controls": {
          "type": "object",
          "additionalProperties": false,
          "required": ["evidence_id", "path", "sha256"],
          "properties": {
            "evidence_id": {"$ref": "#/$defs/uuid"},
            "path": {"type": "string", "minLength": 1, "maxLength": 512},
            "sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "security_scan": {"$ref": "#/$defs/evidence_reference_list"},
        "regression_test": {"$ref": "#/$defs/evidence_reference_list"},
        "rehearsal": {"$ref": "#/$defs/evidence_reference_list"}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_id",
        "role",
        "approved_at",
        "expires_at",
        "signature_reference"
      ],
      "properties": {
        "operator_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "role": {"const": "production-admission-approver"},
        "approved_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "signature_reference": {"const": "#/signature"}
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value_base64"],
      "properties": {
        "algorithm": {"const": "Ed25519"},
        "key_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "value_base64": {"type": "string", "minLength": 1, "maxLength": 256}
      }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 512},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "evidence_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "observed_at", "expires_at"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 512},
        "sha256": {"$ref": "#/$defs/sha256"},
        "observed_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"}
      }
    },
    "evidence_reference_list": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {"$ref": "#/$defs/evidence_reference"}
    },
    "image_digests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api", "dashboard", "web"],
      "properties": {
        "api": {"$ref": "#/$defs/sha256"},
        "dashboard": {"$ref": "#/$defs/sha256"},
        "web": {"$ref": "#/$defs/sha256"}
      }
    },
    "release_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_commit",
        "git_tree",
        "compose_sha256",
        "policy_sha256",
        "trusted_keyring_sha256",
        "model_artifact_digest",
        "image_digests"
      ],
      "properties": {
        "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "git_tree": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "compose_sha256": {"$ref": "#/$defs/sha256"},
        "policy_sha256": {"$ref": "#/$defs/sha256"},
        "trusted_keyring_sha256": {"$ref": "#/$defs/sha256"},
        "model_artifact_digest": {"$ref": "#/$defs/sha256"},
        "image_digests": {"$ref": "#/$defs/image_digests"}
      }
    }
  }
}
