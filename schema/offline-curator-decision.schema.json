{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skill-parser.pingqlin.dev/schema/curation/v1/offline-curator-decision.schema.json",
  "title": "Skill-0 Offline Curator Decision",
  "description": "Structured output from an offline or manual Curator before proposal validation.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "contract_version",
    "prompt_package_checksum",
    "operation",
    "rationale_summary",
    "confidence"
  ],
  "properties": {
    "contract_version": {
      "const": "1.0.0"
    },
    "prompt_package_checksum": {
      "$ref": "#/definitions/checksum"
    },
    "operation": {
      "type": "string",
      "enum": [
        "insert",
        "update",
        "delete"
      ]
    },
    "target_skill_id": {
      "$ref": "#/definitions/skill_id"
    },
    "proposed_skill_id": {
      "$ref": "#/definitions/skill_id"
    },
    "rationale_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": {
            "const": "insert"
          }
        }
      },
      "then": {
        "required": [
          "proposed_skill_id"
        ],
        "not": {
          "required": [
            "target_skill_id"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "update"
          }
        }
      },
      "then": {
        "required": [
          "target_skill_id",
          "proposed_skill_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "delete"
          }
        }
      },
      "then": {
        "required": [
          "target_skill_id"
        ],
        "not": {
          "required": [
            "proposed_skill_id"
          ]
        }
      }
    }
  ],
  "definitions": {
    "checksum": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "skill_id": {
      "type": "string",
      "pattern": "^(claude|mcp)__[a-z_]+__[a-z_]+$"
    }
  }
}
