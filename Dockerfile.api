FROM ubuntu:24.04@sha256:4fbb8e6a8395de5a7550b33509421a2bafbc0aab6c06ba2cef9ebffbc7092d90 AS builder

ARG DEBIAN_FRONTEND=noninteractive
ENV VIRTUAL_ENV=/opt/venv \
    PATH=/opt/venv/bin:$PATH

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates python3 python3-venv && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY requirements-api.txt requirements-runtime.txt ./
RUN --mount=type=secret,id=build_ca,required=false \
    set -eu; \
    ca_path="/usr/local/share/ca-certificates/skill0-build-ca.crt"; \
    ca_installed=0; \
    cleanup_ca() { \
        if [ "$ca_installed" = "1" ]; then \
            rm -f "$ca_path"; \
            update-ca-certificates --fresh >/dev/null; \
        fi; \
    }; \
    trap cleanup_ca EXIT; \
    if [ -s /run/secrets/build_ca ]; then \
        cp /run/secrets/build_ca "$ca_path"; \
        update-ca-certificates >/dev/null; \
        ca_installed=1; \
    fi; \
    python3 -m venv "$VIRTUAL_ENV"; \
    pip install --no-cache-dir --upgrade "pip>=26.1.2,<27"; \
    pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu "torch>=2.13,<3"; \
    pip install --no-cache-dir -r requirements-api.txt; \
    pip install --no-cache-dir -r requirements-runtime.txt; \
    pip install --no-cache-dir "setuptools>=83,<84" "filelock>=3.20.3"; \
    pip check

FROM ubuntu:24.04@sha256:4fbb8e6a8395de5a7550b33509421a2bafbc0aab6c06ba2cef9ebffbc7092d90

ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates python3 libgomp1 && \
    rm -rf /var/lib/apt/lists/*

ENV VIRTUAL_ENV=/opt/venv \
    PATH=/opt/venv/bin:$PATH \
    HF_HOME=/app/.cache/huggingface \
    TRANSFORMERS_CACHE=/app/.cache/huggingface \
    TORCH_HOME=/app/.cache/torch

WORKDIR /app

# Create persistent directories before seeding the image.
RUN mkdir -p /app/.cache /app/data /app/runtime-data /app/governance/db /app/bootstrap /app/scripts

# Copy application code
COPY --from=builder /opt/venv /opt/venv
COPY api/ ./api/
COPY asset_registry/ ./asset_registry/
COPY runtime/ ./runtime/
COPY vector_db/ ./vector_db/
COPY parsed/ ./parsed/
COPY schema/ ./schema/
RUN python -c "from vector_db.vector_store import VectorStore; VectorStore('/app/bootstrap/skills.db').close()"
COPY --chmod=755 scripts/docker-entrypoint-api.sh /usr/local/bin/docker-entrypoint-api.sh
COPY scripts/runtime_doctor.py ./scripts/runtime_doctor.py

# Non-root user with correct permissions
RUN chown -R 65532:65532 /app

USER 65532:65532

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD if [ "${SKILL0_ENV:-development}" = "production" ]; then python /app/scripts/runtime_doctor.py --production >/dev/null; fi && \
        python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

ENTRYPOINT ["docker-entrypoint-api.sh"]
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
