FROM python:3.12.13-slim@sha256:0bbd3d5f3abb2024c1b92ce69e8bdfefa17c248999827c34e2ed52ba0772da1b

WORKDIR /app

# Create persistent directories before seeding the image.
RUN mkdir -p /app/.cache /app/data /app/bootstrap

# Install dependencies
COPY requirements-api.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu torch && \
    pip install --no-cache-dir -r requirements-api.txt && \
    pip install --no-cache-dir "setuptools>=78.1.1,<82" "filelock>=3.20.3"

# Copy application code
COPY api/ ./api/
COPY vector_db/ ./vector_db/
COPY parsed/ ./parsed/
COPY schema/ ./schema/
COPY skills.db ./bootstrap/skills.db
COPY scripts/docker-entrypoint-api.sh /usr/local/bin/docker-entrypoint-api.sh

# Non-root user with correct permissions
RUN adduser --disabled-password --gecos "" --no-create-home appuser && \
    chmod +x /usr/local/bin/docker-entrypoint-api.sh && \
    chown -R appuser:appuser /app

ENV HF_HOME=/app/.cache/huggingface \
    TRANSFORMERS_CACHE=/app/.cache/huggingface \
    TORCH_HOME=/app/.cache/torch

USER appuser

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

ENTRYPOINT ["docker-entrypoint-api.sh"]
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
