# Skill-0 Production Environment Configuration
# Copy to .env and set real values — NEVER commit .env with secrets
# These paths match docker-compose.prod.yml container paths.
# For rehearsal or non-default env-file names, pass `--env-file <path>` and set
# SKILL0_ENV_FILE=<same path> so services receive the env values too.

# === Core API ===
SKILL0_DB_PATH=/app/data/skills.db
SKILL0_PARSED_DIR=/app/parsed
SKILL0_ENV=production
SKILL0_ENABLE_DOCS=false

# === Governance ===
SKILL0_GOVERNANCE_DB_PATH=/app/governance/db/governance.db
SKILL0_TOOLS_PATH=/app/tools

# === GPU / Device ===
SKILL0_DEVICE=cpu
# Materialize a symlink-free model directory in the read-only model-cache volume.
SKILL0_EMBEDDING_MODEL=/app/.cache/approved-model
# Compute this with vector_db.model_artifact.compute_model_artifact_digest.
SKILL0_EMBEDDING_MODEL_ARTIFACT_DIGEST=sha256:CHANGE_ME_TO_APPROVED_MODEL_ARTIFACT_DIGEST

# === CORS ===
# Set to your actual production domain(s)
CORS_ORIGINS=https://your-domain.com

# === Authentication (JWT) ===
# MUST set a strong random secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_REAL_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
API_USERNAME=CHANGE_ME_API_USERNAME
API_PASSWORD=CHANGE_ME_API_PASSWORD
API_PORT=8080
WEB_PORT=3080

# === Rate Limiting ===
API_RATE_LIMIT=60/minute
AUTH_RATE_LIMIT=5/minute

# === Runtime v4 approval binding ===
# MUST be an independent secret of at least 32 characters.
SKILL0_RUNTIME_BINDING_KEY=CHANGE_ME_TO_AN_INDEPENDENT_RUNTIME_SECRET
SKILL0_RUNTIME_DB_PATH=/app/runtime-data/runtime.db
SKILL0_RUNTIME_DECISION_ACTORS=CHANGE_ME_APPROVER_SUBJECTS
SKILL0_RUNTIME_HITL_TTL_SECONDS=86400
SKILL0_RUNTIME_JOURNAL_MODE=WAL
# Set true only for the first intentional provisioning boot, then return to false.
SKILL0_RUNTIME_ALLOW_INITIALIZE=false

# === Logging ===
SKILL0_LOG_LEVEL=WARNING
SKILL0_LOG_FORMAT=json
