{
  "manifest_version": 3,
  "name": "Video-Full",
  "version": "1.0.0",
  "description": "Split multiple videos into a fullscreen grid layout on any page.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Video-Full"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
